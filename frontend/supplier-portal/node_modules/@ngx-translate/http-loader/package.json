{
  "name": "@ngx-translate/http-loader",
  "version": "18.0.0",
  "description": "http loader for dynamically loading translation files for @ngx-translate/core",
  "keywords": [
    "@ngx-translate",
    "ngx-translate",
    "angular",
    "i18n",
    "translation"
  ],
  "author": "Andreas Löw / CodeAndWeb GmbH, Olivier Combe",
  "license": "MIT",
  "peerDependencies": {
    "@angular/common": ">=18",
    "@angular/core": ">=18",
    "@ngx-translate/core": ">=18.0.0"
  },
  "sideEffects": false,
  "module": "fesm2022/ngx-translate-http-loader.mjs",
  "typings": "types/ngx-translate-http-loader.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./types/ngx-translate-http-loader.d.ts",
      "default": "./fesm2022/ngx-translate-http-loader.mjs"
    }
  },
  "type": "module",
  "dependencies": {
    "tslib": "^2.3.0"
  }
}