{
  "ConnectionStrings": {
    "DefaultConnection": "Server=182.78.194.30\\SQL2017,2017;Database=WebProlific;User Id=opm1;Password=;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Key": "DevSecretKey_ChangeInProduction_32Chars!",
    "Issuer": "WebProlific",
    "Audience": "WebProlific",
    "ExpiryMinutes": 480
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] [{CorrelationId}] [{RequestId}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/webprolific-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] [{CorrelationId}] [{RequestId}] [{SourceContext}] [{MachineName}] [{ClientIp}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithClientIp",
      "WithCorrelationId"
    ],
    "Properties": {
      "Application": "WebProlific.Api"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Localization": {
    "SupportedLanguages": ["en", "ar", "vi", "th"],
    "DefaultLanguage": "en",
    "ResourcesPath": "Resources"
  },
  "Currency": {
    "DefaultCurrency": "INR",
    "SupportedCurrencies": ["USD", "EUR", "GBP", "INR", "AED", "VND", "THB"],
    "ExchangeRateProviderUrl": "https://api.exchangerate.host/latest"
  }
